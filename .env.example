# Django Settings
SECRET_KEY=django-insecure-premium-shop-ai-secret-key-placeholder
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database Configuration (Optional, falls back to SQLite if empty)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/premiumshop

# Redis and Celery Caching/Broker Configurations
REDIS_URL=redis://127.0.0.1:6379/1
CELERY_BROKER_URL=redis://127.0.0.1:6379/2

# Payments Integration
STRIPE_PUBLISHABLE_KEY=pk_test_placeholder
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder

RAZORPAY_KEY_ID=rzp_test_placeholder
RAZORPAY_KEY_SECRET=key_secret_placeholder

# Email Server Settings (For Celery email tasks)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@example.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=PremiumShop AI <noreply@premiumshop.ai>
